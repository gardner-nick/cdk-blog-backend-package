{
  "name": "@gardner-nick/cdk-blog-backend",
  "version": "0.1.0",
  "description": "A reusable AWS CDK construct for a serverless blog backend (API Gateway HTTP API + Lambda + DynamoDB, optional S3 assets).",
  "repository": {
    "type": "git",
    "url": "https://github.com/gardner-nick/cdk-blog-backend-package.git"
  },
  "license": "MIT",
  "author": "Nick Gardner",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:handler && npm run build:lib",
    "build:handler": "node esbuild.config.js",
    "build:lib": "tsc -p tsconfig.json",
    "typecheck:handler": "tsc -p handler/tsconfig.json",
    "pretest": "npm run build:handler",
    "test": "jest",
    "prepack": "npm run build"
  },
  "keywords": [
    "cdk",
    "aws-cdk",
    "blog",
    "serverless",
    "construct"
  ],
  "peerDependencies": {
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@types/aws-lambda": "^8.10.138",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "aws-cdk-lib": "^2.150.0",
    "aws-sdk-client-mock": "^4.0.1",
    "constructs": "^10.3.0",
    "esbuild": "^0.23.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
  }
}
